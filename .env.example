# Email delivery (SMTP)
# Used by src/app/api/contact/route.ts

# Where contact form messages are delivered
CONTACT_TO_EMAIL=aidoecompany@gmail.com

# SMTP server settings (example: Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# SMTP authentication
# For Gmail, use an App Password (recommended), not your normal password.
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_app_password_here

# Optional: From address shown in the email
# If omitted, defaults to SMTP_USER
SMTP_FROM=your_gmail_address@gmail.com
